{
  "name": "recettes-personnalisees",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @recettes/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=high",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:lint": "supabase db lint --local --level warning --fail-on warning",
    "supabase:test": "supabase test db --local supabase/tests",
    "supabase:test:auth": "node scripts/test-auth-local.mjs",
    "supabase:taxonomy:import": "node scripts/import-taxonomy.mjs",
    "supabase:ciqual:import": "node scripts/import-ciqual.mjs",
    "supabase:migration:new": "supabase migration new",
    "supabase:types": "supabase gen types typescript --local --schema public > apps/web/src/types/database.generated.ts && prettier --write apps/web/src/types/database.generated.ts",
    "supabase:verify": "npm run supabase:reset && npm run supabase:taxonomy:import && npm run supabase:ciqual:import && npm run supabase:lint && npm run supabase:test && npm run supabase:types",
    "check": "npm run lint && npm run typecheck && npm run test",
    "validate": "npm run format:check && npm run check && npm run build"
  },
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.7",
    "prettier": "^3.6.2",
    "read-excel-file": "^9.3.4",
    "supabase": "^2.109.1"
  }
}
