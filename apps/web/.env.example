# Environnement : local | test | staging | production
APP_ENV=local
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Valeurs locales retournées par `npm run supabase:start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Observabilité inactive tant qu'aucun projet Sentry n'est relié
OBSERVABILITY_ENABLED=false
NEXT_PUBLIC_OBSERVABILITY_ENABLED=false
LOG_LEVEL=debug
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=

# Analytics produit, à activer après validation du plan
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Variables privées : ne jamais les préfixer par NEXT_PUBLIC_
# Laisser désactivé tant que les comptes, quotas et contrôles ne sont pas validés
AI_GENERATION_ENABLED=false
AI_TEXT_PROVIDER=groq
AI_TEXT_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=

AI_TEXT_FALLBACK_PROVIDER=cloudflare
CLOUDFLARE_TEXT_MODEL=@cf/qwen/qwen3-30b-a3b-fp8

AI_IMAGE_PROVIDER=cloudflare
AI_IMAGE_MODEL=@cf/black-forest-labs/flux-2-klein-4b
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Clé de service facultative, strictement côté serveur
SUPABASE_SERVICE_ROLE_KEY=
